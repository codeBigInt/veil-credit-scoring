export circuit recomputeAndReturnScore(
    _userPk: Bytes<32>,
    _issuerPk: Bytes<32>
): CustomStructs_CreditScore {
    assert (LedgerStates_issuers.member(disclose(_issuerPk)), "Unauthorized issuer");

    const userPk = disclose(_userPk);
    return Utils_recomputeAndPersistScore(userPk);
}

export circuit createScoreEntry(): []{
    const userPk = Utils_generateUserPk(disclose(Utils_getLocalSecreteKey()));

    const userCreditScore = disclose(Utils_getCreditScoreByPk(userPk));
    assert (!userCreditScore.is_some, "Not allowed to create duplicated credit score position");
    
    const firstFreeAccumulatorIndex = disclose(Utils_getFirstFreeAccumulatorIndex());
    const firstFreeCreditScoreIndex = disclose(Utils_getFirstFreeCreditScoreIndex());
    

    const newCreditScore = CustomStructs_CreditScore {
        ...default<CustomStructs_CreditScore>,
        mtIndex: firstFreeCreditScoreIndex
    };

    const newScoreAccumulator = CustomStructs_ScoreAccumulators {
        ...default<CustomStructs_ScoreAccumulators>,
        mtIndex: firstFreeAccumulatorIndex
    };

    Utils_updatedAccumulatedScore(userPk, newScoreAccumulator);
    Utils_updatedCreditScore(userPk,newCreditScore);

    const creditScoreCommitment = persistentCommit<CustomStructs_CreditScore>(
        newCreditScore,
        userPk
    );

    const accumulationCommitment = persistentCommit<CustomStructs_ScoreAccumulators>(
        newScoreAccumulator,
        userPk
    );

    LedgerStates_creditScoreCommitments.insert(creditScoreCommitment);
    LedgerStates_scoreAccumulatorCommitments.insert(accumulationCommitment);
    LedgerStates_userCreditScoreIndex.insert(userPk, firstFreeCreditScoreIndex);
    LedgerStates_userAccumulatorIndex.insert(userPk, firstFreeAccumulatorIndex);
}
