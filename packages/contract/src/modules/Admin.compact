module Admin {
    import CompactStandardLibrary;
    import Utils prefix Utils_;
    import GlobalLedgerStates prefix LedgerStates_;
    import CustomStructs prefix CustomStructs_;

    export circuit addIssuer(
        _protocolName: Opaque<"string">,
        _contractAddress: ContractAddress,
    ): Bytes<32>{
        const authSignatureStatus = Utils_assertAuthorization(disclose(Utils_getLocalSecreteKey()));
        assert (authSignatureStatus, "Unauthorized");

        const localSecreteKey = disclose(Utils_getLocalSecreteKey());
        const newIssuerPk = Utils_generateIssuerPk(localSecreteKey);

        assert (!LedgerStates_issuers.member(newIssuerPk), "Issuer with specified key already exists");
        const currentTime = Utils_retieveAndVerifyCurrentTime();

        const newIssuer = CustomStructs_Issuer{
            ...default<CustomStructs_Issuer>,
            isApproved: true,
            registeredEpoch: currentTime,
            contractAddress: disclose(_contractAddress),
            protocolName: disclose(_protocolName)
        };

        LedgerStates_issuers.insert(newIssuerPk, newIssuer);

        return newIssuerPk;
    }

    export circuit removeIssuer(
        _issuerPk: Bytes<32>
    ): []{
        const disclosedIssuerPk = disclose(_issuerPk);
        assert (LedgerStates_issuers.member(disclosedIssuerPk), "Issuer with specified key does not exist");
        
        const authSignatureStatus = Utils_assertAuthorization(disclose(Utils_getLocalSecreteKey()));
        assert (authSignatureStatus, "Unauthorized");

        LedgerStates_issuers.remove(disclosedIssuerPk);
    }

    export circuit updateTokenUris(
        _tokenImageUris: CustomStructs_TokenImageUris
    ): []{
        const authSignatureStatus = Utils_assertAuthorization(disclose(Utils_getLocalSecreteKey()));
        assert (authSignatureStatus, "Unauthorized");

        LedgerStates_tokenImageUris = disclose(_tokenImageUris);
    }

    export circuit addAdmin(
        _adminPk: Bytes<32>
    ): []{
        const superAdminpk = Utils_generateAdminPk(Utils_getLocalSecreteKey());
        assert (superAdminpk == LedgerStates_superAdmin, "Unauthorized");

        const newAdminPk = Utils_generateUserPk(disclose(Utils_getLocalSecreteKey()));
        LedgerStates_admins.insert(newAdminPk);
    }

    export circuit removeAdmin(
        _adminPk: Bytes<32>
    ): []{
        const authSignatureStatus = Utils_assertAuthorization(disclose(Utils_getLocalSecreteKey()));
        assert (authSignatureStatus, "Unauthorized");

        LedgerStates_admins.remove(disclose(_adminPk));
    }

    export circuit updatedProtocolConfig(
        _updatedConfig: CustomStructs_ProtocolConfig
    ): []{
        const authSignatureStatus = Utils_assertAuthorization(disclose(Utils_getLocalSecreteKey()));
        assert (authSignatureStatus, "Unauthorized");

        LedgerStates_protocolConfig = disclose(_updatedConfig);
    }

    export circuit updatedScoreConfig(
        _updatedScoreConfig: CustomStructs_ScoreConfig
    ): []{
        const authSignatureStatus = Utils_assertAuthorization(disclose(Utils_getLocalSecreteKey()));
        assert (authSignatureStatus, "Unauthorized");

        LedgerStates_scoreConfig = disclose(_updatedScoreConfig);
    }
}
